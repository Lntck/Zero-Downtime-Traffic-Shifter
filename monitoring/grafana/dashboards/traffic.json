{
  "uid": "zdt-traffic",
  "title": "Zero-Downtime Traffic",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests by status",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (status) (rate({job=\"nginx\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Requests by upstream color",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (upstream_color) (rate({job=\"nginx\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "stat",
      "title": "5xx per minute",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"nginx\", status=~\"5..\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 }
    }
  ]
}
